# Gmail credentials — REQUIRED
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
SENDER_NAME=Your Full Name

# Test mode — used with --test flag
# All emails will be sent to this address instead of real recipients
TEST_EMAIL=your@gmail.com

# Anti-spam delay between sends (seconds, randomised within this range)
DELAY_MIN_SECONDS=30
DELAY_MAX_SECONDS=60

# Daily sending cap (Gmail free allows ~500/day, keep buffer for safety)
DAILY_SEND_CAP=200

# Retry settings
MAX_RETRIES=3

# Parallel drafting threads (more = faster drafting, but heavier on Phi-4)
DRAFT_WORKERS=3
